version: '3.8'

services:
  postgres:
    image: postgres:15-alpine
    container_name: neonoble-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: neonoble
      POSTGRES_PASSWORD: neonoble123
      POSTGRES_DB: neonoble_ramp
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U neonoble"]
      interval: 10s
      timeout: 5s
      retries: 5

volumes:
  postgres_data:
    driver: local